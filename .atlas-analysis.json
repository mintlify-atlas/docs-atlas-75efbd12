  "keyFeatures": [
    "Simple, well-documented Strategy and Backtest API",
    "Blazing fast execution via NumPy vectorization",
    "Built-in parameter optimizer with grid and sambo-based search",
    "Interactive Bokeh-powered visualizations with equity curves and trade markers",
    "Support for stop-loss, take-profit, limit, and stop-limit orders",
    "Multiple time frame analysis with resample_apply",
    "Indicator-library-agnostic (works with TA-Lib, pandas-ta, etc.)",
    "Composable base strategies: SignalStrategy, TrailingStrategy",
    "Fractional share and cryptocurrency trading via FractionalBacktest",
    "Multi-asset parallel backtesting with MultiBacktest",
    "Detailed performance metrics: Sharpe, Sortino, Calmar, SQN, Kelly, CAGR, drawdown"
  ],
